{
  "name": "@zenofolio/hyper-decor",
  "version": "2.1.1",
  "description": "Project core with utilities and features",
  "main": "dist/index.js",
  "author": "zenozaga <zenozaga@gmail.com> (https://github.com/zenozaga)",
  "license": "MIT",
  "repository": "github:zenofolio/hyper-decor",
  "bugs": {
    "url": "https://github.com/zenofolio/hyper-decor/issues"
  },
  "homepage": "https://github.com/zenofolio/hyper-decor#readme",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build": "tsc",
    "publish": "npm run build && npm publish --access public",
    "bench:chaos": "tsx benches/chaos-storm.ts",
    "bench:throughput": "tsx benches/throughput.ts",
    "bench:metrics:redis": "tsx benches/redis-metrics.ts",
    "bench:concurrency": "tsx benches/concurrency.ts",
    "bench:cron": "tsx benches/cron-distributed.ts"
  },
  "peerDependencies": {
    "hyper-express": "^6.17.3",
    "ioredis": "^5.10.1",
    "nats": "^2.29.3"
  },
  "devDependencies": {
    "@types/file-type": "10.6.0",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.0.18",
    "ioredis": "^5.10.1",
    "nats": "^2.29.3",
    "nodemon": "3.1.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.6.2",
    "undici": "^7.24.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "croner": "^10.0.1",
    "file-type": "^19.5.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "nats": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "node": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./decorators/*": {
      "node": "./dist/decorators/*.js",
      "default": "./dist/decorators/*.js"
    },
    "./helpers/*": {
      "node": "./dist/common/helpers/*.js",
      "default": "./dist/common/helpers/*.js"
    },
    "./collectors/*": {
      "node": "./dist/common/collectors/*.js",
      "default": "./dist/common/collectors/*.js"
    },
    "./exceptions/*": {
      "node": "./dist/common/exceptions/*.js",
      "default": "./dist/common/exceptions/*.js"
    },
    "./extension": {
      "node": "./dist/extension.js",
      "default": "./dist/extension.js"
    },
    "./testing": {
      "node": "./dist/common/testing.js",
      "default": "./dist/common/testing.js"
    },
    "./openapi": {
      "node": "./dist/lib/openapi/index.js",
      "default": "./dist/lib/openapi/index.js"
    },
    "./openapi/*": {
      "node": "./dist/lib/openapi/*.js",
      "default": "./dist/lib/openapi/*.js"
    },
    "./natsmq": {
      "node": "./dist/lib/natsmq/index.js",
      "default": "./dist/lib/natsmq/index.js"
    },
    "./lock": {
      "node": "./dist/lib/lock/index.js",
      "default": "./dist/lib/lock/index.js"
    }
  },
  "bin": {
    "hyper-clean-uws": "./scripts/clean.js"
  }
}