{
  "name": "@zenofolio/hyper-decor",
  "version": "1.0.9",
  "description": "Project core with utilities and features",
  "main": "dist/index.js",
  "author": "zenozaga",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenofolio/hyper-decor.git"
  },
  "bugs": {
    "url": "https://github.com/zenofolio/hyper-decor/issues"
  },
  "homepage": "https://github.com/zenofolio/hyper-decor#readme",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build": "tsc",
    "publish": "npm run build && npm publish --access public",
    "bench:chaos": "tsx benches/chaos-storm.ts",
    "bench:throughput": "tsx benches/throughput.ts",
    "bench:metrics:redis": "tsx benches/redis-metrics.ts",
    "bench:concurrency": "tsx benches/concurrency.ts",
    "bench:cron": "tsx benches/cron-distributed.ts"
  },
  "peerDependencies": {
    "hyper-express": "^6.17.3",
    "ioredis": "^5.10.1",
    "nats": "^2.29.3"
  },
  "devDependencies": {
    "@types/file-type": "10.6.0",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.0.18",
    "ioredis": "^5.10.1",
    "nats": "^2.29.3",
    "nodemon": "3.1.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.6.2",
    "undici": "^7.24.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@zenofolio/hyper-decor": "file:",
    "croner": "^10.0.1",
    "file-type": "^19.5.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "nats": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "node": "./dist/index.js",
      "import": "./src/index.ts"
    },
    "./decorators/*": {
      "node": "./dist/decorators/*.js",
      "default": "./src/decorators/*.ts"
    },
    "./helpers/*": {
      "node": "./dist/common/helpers/*.js",
      "default": "./src/common/helpers/*.ts"
    },
    "./collectors/*": {
      "node": "./dist/common/collectors/*.js",
      "default": "./src/common/collectors/*.ts"
    },
    "./exceptions/*": {
      "node": "./dist/common/exceptions/*.js",
      "default": "./src/common/exceptions/*.ts"
    },
    "./extension": {
      "node": "./dist/extension.js",
      "default": "./src/extension.ts"
    },
    "./testing": {
      "node": "./dist/common/testing.js",
      "default": "./src/common/testing.ts"
    },
    "./openapi": {
      "node": "./dist/lib/openapi/index.js",
      "default": "./src/lib/openapi/index.ts"
    },
    "./openapi/*": {
      "node": "./dist/lib/openapi/*.js",
      "default": "./src/lib/openapi/*.ts"
    }
  },
  "bin": {
    "hyper-clean-uws": "./scripts/clean.js"
  }
}